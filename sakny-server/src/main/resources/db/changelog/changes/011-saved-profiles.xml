<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011-create-saved-profiles-table" author="sakany-team">
        <createTable tableName="saved_profiles">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_saved_profiles_user" references="users(id)"/>
            </column>
            <column name="saved_user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_saved_profiles_saved_user" references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="saved_profiles"
            columnNames="user_id, saved_user_id"
            constraintName="uq_saved_profiles_user_saved"/>

        <createIndex indexName="idx_saved_profiles_user_id" tableName="saved_profiles">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
