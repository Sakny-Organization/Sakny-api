<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-add-property-extended-fields" author="sakany-team">
        <addColumn tableName="properties">
            <column name="deposit" type="DECIMAL(12,2)"/>
            <column name="minimum_stay_months" type="INTEGER"/>
            <column name="payment_period" type="VARCHAR(20)"/>
            <column name="max_occupancy" type="INTEGER"/>
            <column name="parking_spots" type="INTEGER" defaultValueNumeric="0"/>
            <column name="utilities_included" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="internet_included" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="pets_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="smoking_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="preferred_tenant" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
