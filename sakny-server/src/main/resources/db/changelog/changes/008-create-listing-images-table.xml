<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="008-create-listing-images-table" author="Sakny Team">
        <createTable tableName="listing_images">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="listing_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_listing_images_listing"
                             references="listings(id)"
                             deleteCascade="true"/>
            </column>
            <column name="image_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="INTEGER" defaultValueNumeric="0"/>
            <column name="is_primary" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_listing_images_listing_id" tableName="listing_images">
            <column name="listing_id"/>
        </createIndex>

        <setTableRemarks tableName="listing_images" remarks="Images associated with listings"/>
    </changeSet>

</databaseChangeLog>

