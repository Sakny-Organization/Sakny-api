<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="013-create-verification-submissions" author="sakny-team">
        <createTable tableName="verification_submissions">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_verification_user"
                             references="users(id)"
                             deleteCascade="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="front_id_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="back_id_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="selfie_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="external_reference" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_verification_user_id" tableName="verification_submissions">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_verification_status" tableName="verification_submissions">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_verification_external_ref" tableName="verification_submissions">
            <column name="external_reference"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
