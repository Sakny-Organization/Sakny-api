<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-create-listings-table" author="Sakny Team">
        <createTable tableName="listings">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_listings_user"
                             references="users(id)"/>
            </column>
            <column name="title" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="rent_amount" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="property_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="room_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="total_bedrooms" type="INTEGER"/>
            <column name="total_roommates" type="INTEGER"/>
            <column name="current_roommates" type="INTEGER" defaultValueNumeric="0"/>
            <column name="preferred_gender" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="minimum_stay_months" type="INTEGER"/>
            <column name="available_from" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="governorate_id" type="INTEGER">
                <constraints nullable="false"
                             foreignKeyName="fk_listings_governorate"
                             references="governorates(id)"/>
            </column>
            <column name="city_id" type="INTEGER">
                <constraints nullable="false"
                             foreignKeyName="fk_listings_city"
                             references="cities(id)"/>
            </column>
            <column name="address" type="VARCHAR(500)"/>
            <column name="amenities" type="TEXT"/>
            <column name="bills_included" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="pets_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="smoking_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for common queries -->
        <createIndex indexName="idx_listings_user_id" tableName="listings">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_listings_status" tableName="listings">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_listings_governorate" tableName="listings">
            <column name="governorate_id"/>
        </createIndex>

        <createIndex indexName="idx_listings_city" tableName="listings">
            <column name="city_id"/>
        </createIndex>

        <createIndex indexName="idx_listings_rent_amount" tableName="listings">
            <column name="rent_amount"/>
        </createIndex>

        <createIndex indexName="idx_listings_available_from" tableName="listings">
            <column name="available_from"/>
        </createIndex>

        <setTableRemarks tableName="listings" remarks="Room and apartment listings for roommate matching"/>
    </changeSet>

</databaseChangeLog>

