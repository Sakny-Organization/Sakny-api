<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-add-reservation-indexes" author="sakny">
        <createIndex indexName="idx_reservations_property_id" tableName="reservations">
            <column name="property_id"/>
        </createIndex>

        <createIndex indexName="idx_reservations_user_id" tableName="reservations">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_reservations_status" tableName="reservations">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
